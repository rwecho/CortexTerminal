<?xml version="1.0" encoding="utf-8"?>
<resources>
  <style name="CortexTerminal.MainTheme" parent="Maui.MainTheme.NoActionBar">
    <item name="android:windowBackground">@color/maui_splash_color</item>
    <item name="android:colorBackground">@color/maui_splash_color</item>
    <item name="android:statusBarColor">@color/maui_splash_color</item>
    <item name="android:navigationBarColor">@color/maui_splash_color</item>
    <item name="android:navigationBarDividerColor">@color/maui_splash_color</item>
    <item name="android:windowLightStatusBar">false</item>
    <item name="android:windowLightNavigationBar">false</item>
    <item name="android:enforceNavigationBarContrast">false</item>
    <item name="android:enforceStatusBarContrast">false</item>
  </style>

  <style name="CortexTerminal.SplashTheme" parent="Maui.SplashTheme">
    <item name="android:windowBackground">@drawable/maui_splash</item>
    <item name="android:windowSplashScreenBackground">@color/maui_splash_color</item>
    <item name="android:windowSplashScreenIconBackgroundColor">@color/maui_splash_color</item>
    <item name="android:statusBarColor">@color/maui_splash_color</item>
    <item name="android:navigationBarColor">@color/maui_splash_color</item>
    <item name="android:navigationBarDividerColor">@color/maui_splash_color</item>
    <item name="android:windowLightStatusBar">false</item>
    <item name="android:windowLightNavigationBar">false</item>
    <item name="android:enforceNavigationBarContrast">false</item>
    <item name="android:enforceStatusBarContrast">false</item>
  </style>
</resources>